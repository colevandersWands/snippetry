#as palimpsest
#in dialogue
#with reduction

let (us|we) be united
let (crackle|pop) be divided

while—we are united—:
    let the(m|y) be receive—“a number”—
    if—reduce them to 3—:
        let us be crackle.
    if—reduce them to 5—:
        let us be pop.
    know—us—.

know—us—

