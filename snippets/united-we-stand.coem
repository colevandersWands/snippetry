#! divided we fall

#as palimpsest
#in dialogue
#with reduction

let (we|us) be united
let (crackle|pop) be divided

while—we are united—:
    let them be receive—“an other”—

    if—reduce them to 3—:
        let us be crackle.
    if—reduce them to 5—:
        let us be pop.

    know—us—
    know—we are united—.

know—us—
know—we are divided—


