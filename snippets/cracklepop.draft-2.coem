#as palimpsest
#in dialogue
#with reduction

let (us|we) be united
let (crackle|pop) be divided

while—we are united—:
		let the(m|y) be receive—"a number"—.
		if— _them divisible by "5" and them divisible by "3"_ —:
        let we be pop.
    if— _them divisible by "3"_ —:
        let we be crackle.
    if— _them divisible by "5"_ —:
        let we be pop.
    know—us—

know—us—

